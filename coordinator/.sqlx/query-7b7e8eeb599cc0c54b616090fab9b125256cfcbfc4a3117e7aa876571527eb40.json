  "query": "\n        SELECT provider_id, floor_price_nmc_per_hour, trust_score, jobs_completed\n        FROM providers\n        WHERE state = 'available'\n          AND max_job_ram_gb >= $1\n          AND floor_price_nmc_per_hour <= $2\n        ORDER BY floor_price_nmc_per_hour ASC\n        LIMIT 20\n        ",
